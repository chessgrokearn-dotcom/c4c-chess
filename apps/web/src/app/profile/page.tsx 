'use client';

import { useEffect } from 'react';
import { useRouter } from 'next/navigation';
import { useAccount, useDisconnect } from 'wagmi';
import { C4C_TOKEN_ADDRESS } from '@/lib/config';

export default function ProfilePage() {
  const { address, isConnected } = useAccount();
  const { disconnect } = useDisconnect();
  const router = useRouter();

  // 🔥 Защита: если не подключён → редирект на главную
  useEffect(() => {
    if (!isConnected) {
      router.replace('/');
    }
  }, [isConnected, router]);

  if (!isConnected || !address) {
    return (
      <div className="min-h-screen bg-gray-900 flex items-center justify-center text-gray-400">
        Redirecting...
      </div>
    );
  }

  return (
    <main className="min-h-screen bg-gray-900 text-white p-6">
      <div className="max-w-xl mx-auto space-y-6">
        <div className="flex justify-between items-center pb-4 border-b border-gray-800">
          <h1 className="text-2xl font-bold">♟️ Profile</h1>
          <button
            onClick={() => disconnect()}
            className="px-3 py-1.5 bg-red-600/20 hover:bg-red-600/40 text-red-400 rounded-lg text-sm"
          >
            Disconnect
          </button>
        </div>

        <div className="p-5 bg-gray-800 rounded-xl border border-gray-700">
          <p className="text-xs text-gray-500 mb-1">Connected Wallet</p>
          <p className="font-mono text-sm text-green-400 break-all">{address}</p>
          <p className="text-xs text-gray-500 mt-3 mb-1">Token Address</p>
          <p className="font-mono text-xs text-blue-400 break-all">{C4C_TOKEN_ADDRESS}</p>
        </div>

        <div className="p-5 bg-gray-800/50 rounded-xl border border-gray-700 text-center">
          <p className="text-gray-400">Create Game form coming in Phase 3</p>
        </div>
      </div>
    </main>
  );
}